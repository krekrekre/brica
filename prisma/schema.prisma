generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  phone         String?
  role          String    @default("USER") // "ADMIN", "EMPLOYEE", "USER"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relationships
  appointments  Appointment[] @relation("UserAppointments")
  schedules     Schedule[]
  irregularSchedules IrregularSchedule[]
  timeOffs      TimeOff[]
  appointmentsAsEmployee Appointment[] @relation("EmployeeAppointments")
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String?
  duration    Int      // in minutes
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointments Appointment[]
}

model Schedule {
  id         String   @id @default(cuid())
  employeeId String
  dayOfWeek  Int      // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  startTime  String   // HH:mm format, e.g., "09:00"
  endTime    String   // HH:mm format, e.g., "17:00"
  
  employee   User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model IrregularSchedule {
  id         String   @id @default(cuid())
  employeeId String
  startDate  DateTime // First date of the schedule (date part only)
  endDate    DateTime // Last date (same as startDate for single day)
  startTime  String   // HH:mm
  endTime    String   // HH:mm

  employee   User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model TimeOff {
  id         String   @id @default(cuid())
  employeeId String
  date       DateTime // The date of the time off
  reason     String?
  
  employee   User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
}

model Settings {
  id                    String @id @default(cuid())
  maxBookingAdvanceDays Int    @default(30)
  appointmentDuration   Int?   @default(30)
  maxBookingsPerMonth   Int    @default(5)
}

model Appointment {
  id          String   @id @default(cuid())
  userId      String?
  employeeId  String
  serviceId   String?
  isPause     Boolean  @default(false)
  startTime   DateTime
  endTime     DateTime
  status      String   @default("CONFIRMED") // "PENDING", "CONFIRMED", "CANCELLED"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?    @relation("UserAppointments", fields: [userId], references: [id], onDelete: Cascade)
  employee    User     @relation("EmployeeAppointments", fields: [employeeId], references: [id], onDelete: Cascade)
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
}
